  travelDate      DateTime?
  returnDate      DateTime?
  notes           String?   @db.Text
  adminNotes      String?   @db.Text
  rejectionReason String?   @db.Text
  documents       Json?
  submittedAt     DateTime?
  reviewedAt      DateTime?
  reviewedBy      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  customer Customer  @relation(fields: [customerId], references: [id])
  booking  Booking?  @relation(fields: [bookingId], references: [id])

  @@index([customerId])
  @@index([status])
  @@map("visa_applications")
}

// === Phase 11: Guide/Tour Leader Recruitment ===

model GuideApplication {
  id             String    @id @default(cuid())
  fullName       String
  email          String
  phone          String
  lineId         String?
  position       String    // TOUR_GUIDE, TOUR_LEADER, LOCAL_GUIDE
  languages      Json
  experience     String?   @db.Text
  destinations   Json?
  licenseNo      String?
  resumeUrl      String?
  photoUrl       String?
  status         String    @default("NEW") // NEW, SCREENING, INTERVIEW_SCHEDULED, INTERVIEWED, ACCEPTED, REJECTED
  interviewDate  DateTime?
  interviewNotes String?   @db.Text
  adminNotes     String?   @db.Text
  reviewedBy     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status])
  @@index([email])
  @@map("guide_applications")
}

// =====================================================
// Phase 12: Affiliate / Commission System
// =====================================================

model Affiliate {
  id              String    @id @default(cuid())
  displayName     String
  email           String    @unique
  phone           String?
  type            String    @default("AFFILIATE_LINK") // INFLUENCER, AFFILIATE_LINK, AGENT_B2B, PRO_STAFF, SUB_AGENT
  tier            String    @default("BRONZE") // BRONZE, SILVER, GOLD, PLATINUM
  status          String    @default("PENDING") // PENDING, ACTIVE, SUSPENDED, TERMINATED
  referralCode    String    @unique
  couponCode      String?   @unique
  parentId        String?   // For sub-agents
  websiteUrl      String?
  socialHandle    String?
  bankName        String?
  bankAccount     String?
  bankAccountName String?
  taxId           String?
  kycStatus       String    @default("PENDING") // PENDING, SUBMITTED, VERIFIED, REJECTED
  kycDocuments    Json?
  totalRevenue    Float     @default(0)
  totalCommission Float     @default(0)
  totalPaid       Float     @default(0)
  cookieDays      Int       @default(30)
  notes           String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  parent         Affiliate?        @relation("SubAffiliates", fields: [parentId], references: [id], onDelete: SetNull)
  children       Affiliate[]       @relation("SubAffiliates")
  commissionRules CommissionRule[]
  ledgerEntries  CommissionLedger[]
  payouts        AffiliatePayout[]
  clicks         AffiliateClick[]

  @@index([type])
  @@index([tier])
  @@index([status])
  @@map("affiliates")
}

model CommissionRule {
  id            String    @id @default(cuid())
  name          String
  priority      Int       @default(5) // P1=1 (override) ... P6=6 (global)
  affiliateId   String?   // null = global rule
  affiliateType String?   // null = all types
  productType   String?   // TOUR, VISA, PRIVATE_GROUP, null = all
  productId     String?   // specific product
  campaignId    String?
  rateType      String    @default("PERCENTAGE") // PERCENTAGE, FLAT
  rateValue     Float
  isStackable   Boolean   @default(true)
  isActive      Boolean   @default(true)
  validFrom     DateTime?
  validUntil    DateTime?
  conditions    Json?     // e.g. { minBookingValue: 10000 }
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  affiliate Affiliate? @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([priority])
  @@index([affiliateType, productType])
  @@map("commission_rules")
}

model CommissionLedger {
  id            String    @id @default(cuid())
  affiliateId   String
  bookingRef    String?
  productType   String    // TOUR, VISA, PRIVATE_GROUP
  bookingValue  Float
  commissionRate Float
  commissionAmount Float
  whtAmount     Float     @default(0) // WHT 3%
  netAmount     Float
  status        String    @default("PENDING") // PENDING, HOLDING, CONFIRMED, APPROVED, PAID, CANCELLED
  rulesApplied  Json?     // snapshot of rules at time of calculation
  payoutId      String?
  approvedBy    String?
  approvedAt    DateTime?
  notes         String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  affiliate Affiliate       @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  payout    AffiliatePayout? @relation(fields: [payoutId], references: [id], onDelete: SetNull)

  @@index([affiliateId, status])
  @@index([status])
  @@map("commission_ledger")
}

model AffiliatePayout {
  id            String    @id @default(cuid())
  affiliateId   String
  payoutRef     String    @unique
  period        String    // e.g. "2569-05"
  grossAmount   Float
  whtAmount     Float     @default(0)
  netAmount     Float
  status        String    @default("PENDING") // PENDING, APPROVED, PROCESSING, PAID, FAILED
  bankFile      String?   // CSV file reference
  whtCertUrl    String?   // WHT certificate PDF
  processedBy   String?
  processedAt   DateTime?
  paidAt        DateTime?
  notes         String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  affiliate     Affiliate          @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  ledgerEntries CommissionLedger[]

  @@index([affiliateId])
  @@index([status])
  @@map("affiliate_payouts")
}

model AffiliateClick {
  id           String    @id @default(cuid())
  affiliateId  String
  referralCode String
  couponCode   String?
  sourceUrl    String?   @db.Text
  landingUrl   String?   @db.Text
  ipAddress    String?
  userAgent    String?   @db.Text
  converted    Boolean   @default(false)
  bookingRef   String?
  createdAt    DateTime  @default(now())

  affiliate Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([affiliateId])
  @@index([referralCode])
  @@index([createdAt])
  @@map("affiliate_clicks")
}

// =====================================================
// Phase 13: Talent / Guide Request System
// =====================================================

model Talent {
  id            String    @id @default(cuid())
  displayName   String
  realName      String?   // private
  email         String    @unique
  phone         String?
  lineId        String?
  photoUrl      String?
  tier          String    @default("NEW") // NEW, STANDARD, SENIOR, PREMIUM, ELITE
  status        String    @default("ACTIVE") // ACTIVE, INACTIVE, ON_LEAVE, SUSPENDED
  region        String?
  languages     String[]
  specialties   String[]
  bio           String?   @db.Text
  experience    String?
  licenseNo     String?
  rating        Float     @default(0)
  reviewCount   Int       @default(0)
  totalTrips    Int       @default(0)
  totalEarnings Float     @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  requests       TalentRequest[]
  scheduleBlocks TalentScheduleBlock[]
  reviews        TalentReview[]
  favorites      TalentFavorite[]
  pricingOverrides TalentPricingOverride[]

  @@index([tier])
  @@index([status])
  @@index([region])
  @@map("talents")
}

model TalentRequest {
  id              String    @id @default(cuid())
  requestRef      String    @unique
  talentId        String
  customerId      String?
  bookingId       String?
  bookingType     String    @default("TOUR") // TOUR, PRIVATE_GROUP
  travelDate      DateTime
  daysCount       Int       @default(1)
  paxCount        Int       @default(1)
  language        String    @default("TH")
  message         String?   @db.Text
  backupTalentId  String?
  status          String    @default("SUBMITTED") // SUBMITTED, PENDING_REVIEW, TALENT_NOTIFIED, CONFIRMED, ALTERNATIVE_OFFERED, CUSTOMER_DECIDED, AUTO_ASSIGNED, COMPLETED, FULL_CANCEL
  premiumAmount   Float     @default(0) // admin manual
  surchargeAmount Float     @default(0)
  discountAmount  Float     @default(0)
  pricingNote     String?
  adminNote       String?   @db.Text
  assignedTalentId String?  // final assigned talent (may differ from requested)
  respondedAt     DateTime?
  confirmedAt     DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?   @db.Text
  refundAmount    Float     @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  talent    Talent   @relation(fields: [talentId], references: [id], onDelete: Restrict)

  @@index([talentId])
  @@index([status])
  @@index([travelDate])
  @@map("talent_requests")
}

model TalentScheduleBlock {
  id        String   @id @default(cuid())
  talentId  String
  startDate DateTime
  endDate   DateTime
  reason    String?  // BOOKED, PERSONAL, HOLIDAY
  requestRef String? // linked to TalentRequest
  createdAt DateTime @default(now())

  talent Talent @relation(fields: [talentId], references: [id], onDelete: Cascade)

  @@index([talentId, startDate, endDate])
  @@map("talent_schedule_blocks")
}

model TalentReview {
  id         String   @id @default(cuid())
  talentId   String
  customerId String?
  requestRef String?
  rating     Int      // 1-5
  comment    String?  @db.Text
  isPublic   Boolean  @default(true)
  isModerated Boolean @default(false)
  createdAt  DateTime @default(now())

  talent Talent @relation(fields: [talentId], references: [id], onDelete: Cascade)

  @@index([talentId])
  @@map("talent_reviews")
}

model TalentFavorite {
  id         String   @id @default(cuid())
  talentId   String
  customerId String
  createdAt  DateTime @default(now())

  talent Talent @relation(fields: [talentId], references: [id], onDelete: Cascade)

  @@unique([customerId, talentId])
  @@map("talent_favorites")
}

model TalentPricingOverride {
  id            String   @id @default(cuid())
  talentId      String?
  requestRef    String?
  adminUserId   String?
  premiumAmount Float    @default(0)
  surcharge     Float    @default(0)
  discount      Float    @default(0)
  reason        String?
  createdAt     DateTime @default(now())

  talent Talent? @relation(fields: [talentId], references: [id], onDelete: Cascade)

  @@map("talent_pricing_overrides")
}

// ═══════════════════════════════════════════════════════════
// PHASE 7 — Infrastructure Models (SEO, Monitoring, Marketing)
// ═══════════════════════════════════════════════════════════

// Seat hold during checkout (TTL-based)
model SeatHold {
  id          String   @id @default(cuid())
  departureId String
  seats       Int
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  departure Departure @relation(fields: [departureId], references: [id], onDelete: Cascade)

  @@index([departureId])
  @@index([expiresAt])
  @@map("seat_holds")
}

// Short links for marketing (jt.lol/xxx)
model ShortLink {
  id        String    @id @default(cuid())
  shortCode String    @unique
  longUrl   String    @db.Text
  campaign  String?
  source    String?
  medium    String?
  clicks    Int       @default(0)
  isActive  Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  events ShortLinkClick[]

  @@map("short_links")
}

// Short link click tracking
model ShortLinkClick {
  id          String   @id @default(cuid())
  shortLinkId String
  ip          String?
  userAgent   String?  @db.Text
  referer     String?
  country     String?
  city        String?
  createdAt   DateTime @default(now())

  shortLink ShortLink @relation(fields: [shortLinkId], references: [id], onDelete: Cascade)

  @@index([shortLinkId])
  @@map("short_link_clicks")
}

// System error log (from ErrorMonitor)
model SystemErrorLog {
  id        String   @id @default(cuid())
  message   String   @db.VarChar(500)
  stack     String?  @db.Text
  severity  String   // LOW, MEDIUM, HIGH, CRITICAL
  category  String   // API, DATABASE, AUTH, PAYMENT, SYNC, AI, WEBHOOK, GENERAL
  context   Json?
  userId    String?
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([severity])
  @@index([category])
  @@index([createdAt])
  @@map("system_error_logs")
}

// Marketing attribution events
model MarketingEvent {
  id          String   @id @default(cuid())
  eventType   String   // PAGE_VIEW, LEAD, BOOKING, CONVERSION
  source      String?  // google, facebook, line, tiktok, direct
  medium      String?  // cpc, organic, social, email
  campaign    String?
  content     String?
  term        String?
  referrer    String?  @db.Text
  landingPage String?  @db.Text
  customerId  String?
  bookingId   String?
  value       Float?   // conversion value in THB
  currency    String   @default("THB")
  sessionId   String?
  ip          String?
  userAgent   String?  @db.Text
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([eventType])
  @@index([source, medium])
  @@index([campaign])
  @@index([createdAt])
  @@map("marketing_events")
}

// UTM parameter capture log
model UtmCapture {
  id           String   @id @default(cuid())
  sessionId    String
  firstTouch   Json?    // First UTM params seen
  lastTouch    Json?    // Last UTM params seen
  touchCount   Int      @default(1)
  customerId   String?
  convertedAt  DateTime?
  conversionId String?  // bookingId or leadId
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([sessionId])
  @@index([customerId])
  @@map("utm_captures")
}

// SEO audit results
model SeoAuditResult {
  id          String   @id @default(cuid())
  url         String
  score       Int      // 0-100
  issues      Json?    // Array of issues found
  category    String?  // technical, content, performance
  checkedAt   DateTime @default(now())

  @@index([url])
  @@map("seo_audit_results")
}
