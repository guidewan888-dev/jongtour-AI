generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// 1. suppliers
model Supplier {
  id            String   @id @default(cuid())
  canonicalName String   @unique
  displayName   String
  status        String   @default("ACTIVE") // ACTIVE, INACTIVE, MAINTENANCE
  bookingMethod String   @default("API") // API, EMAIL, PORTAL
  syncFrequency String   @default("HOURLY") // HOURLY, DAILY, MANUAL
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  aliases          SupplierAlias[]
  apiCredentials   SupplierApiCredential?
  syncLogs         SupplierSyncLog[]
  rawSources       TourRawSource[]
  tours            Tour[]
  departures       Departure[]
  bookings         Booking[]
  users            User[]
  wholesaleRefs    BookingWholesaleRef[]
  wholesaleActions BookingWholesaleAction[]
  credentials      SupplierCredential[]
  automationConfig SupplierAutomationConfig?
  rpaSessions      WholesaleRpaSession[]

  @@map("suppliers")
}

// 2. supplier_aliases
model SupplierAlias {
  id              String   @id @default(cuid())
  supplierId      String
  aliasName       String
  normalizedAlias String   @unique
  createdAt       DateTime @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@map("supplier_aliases")
}

// 3. supplier_api_credentials
model SupplierApiCredential {
  id              String    @id @default(cuid())
  supplierId      String    @unique
  apiBaseUrl      String
  authType        String    @default("BEARER") // BEARER, BASIC, OAUTH2, API_KEY
  encryptedApiKey String?
  encryptedSecret String?
  tokenExpiredAt  DateTime?
  status          String    @default("ACTIVE")

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@map("supplier_api_credentials")
}

// 4. supplier_sync_logs
model SupplierSyncLog {
  id             String    @id @default(cuid())
  supplierId     String
  syncType       String // FULL, INCREMENTAL, PRICE, AVAILABILITY
  status         String // RUNNING, SUCCESS, FAILED
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?
  totalRecords   Int       @default(0)
  successRecords Int       @default(0)
  failedRecords  Int       @default(0)
  errorMessage   String?   @db.Text

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@map("supplier_sync_logs")
}

// 5. tour_raw_sources
model TourRawSource {
  id             String   @id @default(cuid())
  supplierId     String
  externalTourId String
  rawPayload     Json
  rawHash        String
  sourceType     String // API, CSV, SCRAPE
  syncedAt       DateTime @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([supplierId, externalTourId])
  @@map("tour_raw_sources")
}

// 6. tours
model Tour {
  id                  String    @id @default(cuid())
  supplierId          String
  externalTourId      String
  tourCode            String    @unique
  tourName            String
  slug                String    @unique
  tourType            String    @default("GROUP") // GROUP, FIT, PRIVATE
  durationDays        Int
  durationNights      Int
  status              String    @default("DRAFT") // DRAFT, PUBLISHED, ARCHIVED
  sourceUrl           String?
  bookingUrl          String?
  lastSyncedAt        DateTime?
  wholesaleTourUrl    String?
  wholesaleBookingUrl String?
  wholesaleLoginUrl   String?
  wholesaleSearchUrl  String?
  supplierProgramCode String?
  supplierBookingNote String?   @db.Text
  linkHealthStatus    String    @default("UNVERIFIED") // HEALTHY, BROKEN, UNVERIFIED, MISSING
  lastLinkCheckedAt   DateTime?
  linkVerifiedBy      String?
  linkVerifiedAt      DateTime?
  isVisible           Boolean   @default(true)
  isMock              Boolean   @default(false)
  isDemo              Boolean   @default(false)
  excludedFromSearch  Boolean   @default(false)
  excludedFromAi      Boolean   @default(false)
  sourceType          String    @default("API") // API, CSV, SCRAPE, MOCK, DEMO
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  supplier      Supplier          @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  destinations  TourDestination[]
  images        TourImage[]
  pdfs          TourPdf[]
  mapping       TourMapping?
  itineraries   Itinerary[]
  meals         TourMeal[]
  included      TourIncluded[]
  excluded      TourExcluded[]
  policies      TourPolicy[]
  departures    Departure[]
  bookings      Booking[]
  TourEmbedding TourEmbedding?
  favorites     CustomerFavorite[]

  @@unique([supplierId, externalTourId])
  @@map("tours")
}

// 7. tour_destinations
model TourDestination {
  id        String   @id @default(cuid())
  tourId    String
  country   String
  city      String?
  createdAt DateTime @default(now())

  tour Tour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@map("tour_destinations")
}

// 8. tour_images
model TourImage {
  id        String   @id @default(cuid())
  tourId    String
  imageUrl  String
  isCover   Boolean  @default(false)
  altText   String?
  createdAt DateTime @default(now())

  tour Tour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@map("tour_images")
}

// 9. itineraries
model Itinerary {
  id          String   @id @default(cuid())
  tourId      String
  dayNumber   Int
  title       String
  description String   @db.Text
  createdAt   DateTime @default(now())

  tour Tour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@map("itineraries")
}

// 10. tour_meals
model TourMeal {
  id        String   @id @default(cuid())
  tourId    String
  dayNumber Int
  mealType  String // BREAKFAST, LUNCH, DINNER
  details   String?
  createdAt DateTime @default(now())

  tour Tour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@map("tour_meals")
}

// 11. tour_included
model TourIncluded {
  id          String   @id @default(cuid())
  tourId      String
  description String
  createdAt   DateTime @default(now())

  tour Tour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@map("tour_included")
}

// 12. tour_excluded
model TourExcluded {
  id          String   @id @default(cuid())
  tourId      String
  description String
  createdAt   DateTime @default(now())

  tour Tour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@map("tour_excluded")
}

// 13. tour_policies
model TourPolicy {
  id          String   @id @default(cuid())
  tourId      String
  policyType  String // CANCELLATION, REFUND, VISA
  description String   @db.Text
  createdAt   DateTime @default(now())

  tour Tour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@map("tour_policies")
}

// 14. departures
model Departure {
  id                  String   @id @default(cuid())
  tourId              String
  supplierId          String
  externalDepartureId String?
  startDate           DateTime
  endDate             DateTime
  totalSeats          Int      @default(0)
  remainingSeats      Int      @default(0)
  status              String   @default("AVAILABLE") // AVAILABLE, FULL, CANCELLED, ON_REQUEST
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tour             Tour              @relation(fields: [tourId], references: [id], onDelete: Cascade)
  supplier         Supplier          @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  availabilityLogs AvailabilityLog[]
  prices           Price[]
  bookings         Booking[]
  quotations       Quotation[]
  seatHolds        SeatHold[]

  @@unique([tourId, externalDepartureId])
  @@map("departures")
}

// 15. availability_logs
model AvailabilityLog {
  id            String   @id @default(cuid())
  departureId   String
  previousSeats Int
  newSeats      Int
  changedAt     DateTime @default(now())
  reason        String?

  departure Departure @relation(fields: [departureId], references: [id], onDelete: Cascade)

  @@map("availability_logs")
}

// 16. prices
model Price {
  id           String   @id @default(cuid())
  departureId  String
  paxType      String   @default("ADULT") // ADULT, CHILD, INFANT, SINGLE_SUPP
  sellingPrice Float
  netPrice     Float?
  currency     String   @default("THB")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  departure Departure @relation(fields: [departureId], references: [id], onDelete: Cascade)

  @@map("prices")
}

// 17. price_snapshots
model PriceSnapshot {
  id           String   @id @default(cuid())
  bookingId    String
  paxType      String
  sellingPrice Float
  netPrice     Float?
  currency     String   @default("THB")
  createdAt    DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("price_snapshots")
}

// 18. customers
model Customer {
  id        String   @id @default(cuid())
  userId    String?  @unique // Link to users table if registered
  firstName String
  lastName  String
  email     String
  phone     String
  lineId    String?  @unique
  avatarUrl String?
  status    String   @default("ACTIVE") // ACTIVE, INACTIVE, BANNED
  tags      String[] // e.g. VIP, CORPORATE, BLACKLIST
  leadSource String  @default("ORGANIC") // ORGANIC, ADS, REFERRAL, WALK_IN
  internalNotes String? @db.Text
  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?
  passwordHash String?
  mustChangePassword Boolean @default(false)
  lastLoginAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  bookings Booking[]
  socialAccounts CustomerSocialAccount[]
  favorites CustomerFavorite[]
  notifications Notification[]
  supportTickets SupportTicket[]
  documents CustomerDocument[]
  loginHistory CustomerLoginHistory[]
  preference CustomerPreference?
  consent CustomerConsent?
  consentLogs ConsentLog[]
  activityLogs CustomerActivityLog[]
  resetTokens PasswordResetToken[]
  visaApplications VisaApplication[]

  @@map("customers")
}

// 19. agents
model Agent {
  id           String   @id @default(cuid())
  companyName  String
  taxId        String?
  contactName  String
  email        String   @unique
  phone        String
  creditLimit  Float    @default(0)
  balance      Float    @default(0)
  status       String   @default("ACTIVE")
  subdomain    String?  @unique
  tier         String   @default("STANDARD") // STANDARD, BRONZE, SILVER, GOLD
  discountRate Float    @default(0) // Discount percentage
  logoUrl      String?
  themeColor   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users      User[]
  bookings   Booking[]
  quotations Quotation[]

  @@map("agents")
}

// 20. bookings
model Booking {
  id                       String    @id @default(cuid())
  bookingRef               String    @unique
  supplierId               String
  tourId                   String
  departureId              String
  customerId               String
  agentId                  String?
  bookingSource            String    @default("ONLINE") // ONLINE, MANUAL, SALE, AGENT, AI_CHATBOT
  status                   String    @default("PENDING") // pending, waiting_admin_review, waiting_wholesale_booking, waiting_wholesale_confirm, wholesale_confirmed, confirmed, payment_pending, paid, voucher_issued, completed, cancelled, rejected, failed
  wholesaleBookingMethod   String    @default("UNKNOWN") // API_BOOKING, MANUAL_WEBSITE, MANUAL_LINE, MANUAL_EMAIL, MANUAL_PHONE, ON_REQUEST, UNKNOWN
  wholesaleStatus          String    @default("NOT_STARTED") // NOT_STARTED, LINK_READY, MISSING_LINK, OPENED_BY_ADMIN, SENT_TO_WHOLESALE, WAITING_CONFIRM, CONFIRMED, REJECTED, SOLD_OUT, PRICE_CHANGED, MANUAL_FOLLOW_UP_REQUIRED, SUPPLIER_NOT_AVAILABLE
  supplierContactName      String?
  supplierContactChannel   String?
  supplierConfirmedPrice   Float?
  supplierConfirmedStatus  String?
  supplierConfirmedAt      DateTime?
  supplierNote             String?   @db.Text
  internalNote             String?   @db.Text
  uploadedConfirmationFile String?
  centralTourId            String?   @map("central_tour_id")
  centralDepartureId       String?   @map("central_departure_id")
  seatSnapshot             Json?     @map("seat_snapshot")
  pdfUrl                   String?   @map("pdf_url")
  totalPrice               Float
  totalNetPrice            Float?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  supplier  Supplier  @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  tour      Tour      @relation(fields: [tourId], references: [id], onDelete: Restrict)
  departure Departure @relation(fields: [departureId], references: [id], onDelete: Restrict)
  customer  Customer  @relation(fields: [customerId], references: [id], onDelete: Restrict)
  agent     Agent?    @relation(fields: [agentId], references: [id], onDelete: SetNull)

  travelers        BookingTraveler[]
  items            BookingItem[]
  externalRefs     BookingExternalRef?
  payments         Payment[]
  invoices         Invoice[]
  receipts         Receipt[]
  refunds          Refund[]
  vouchers         Voucher[]
  priceSnapshots   PriceSnapshot[]
  documents        CustomerDocument[]
  wholesaleRef     BookingWholesaleRef?
  wholesaleActions BookingWholesaleAction[]
  centralSnapshot  BookingCentralSnapshot?
  rpaSessions      WholesaleRpaSession[]
  rpaActions       WholesaleRpaAction[]
  supportTickets   SupportTicket[]
  visaApplications VisaApplication[]

  @@map("bookings")
}

// 21. booking_travelers
model BookingTraveler {
  id         String    @id @default(cuid())
  bookingId  String
  paxType    String    @default("ADULT") // ADULT, CHILD, INFANT
  title      String?
  firstName  String
  lastName   String
  passportNo String?
  dob        DateTime?
  createdAt  DateTime  @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("booking_travelers")
}

// 22. booking_items
model BookingItem {
  id          String   @id @default(cuid())
  bookingId   String
  itemType    String // TOUR, EXTRA_BED, VISA, INSURANCE
  description String
  quantity    Int
  unitPrice   Float
  totalPrice  Float
  createdAt   DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("booking_items")
}

// 23. booking_external_refs
model BookingExternalRef {
  id                String   @id @default(cuid())
  bookingId         String   @unique
  externalBookingId String
  status            String // CONFIRMED_BY_SUPPLIER, REJECTED
  rawResponse       Json?
  createdAt         DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("booking_external_refs")
}

model BookingCentralSnapshot {
  id                String   @id @default(cuid())
  bookingId         String   @unique @map("booking_id")
  centralTourId     String?  @map("central_tour_id")
  centralDepartureId String? @map("central_departure_id")
  wholesaleId       String?  @map("wholesale_id")
  priceSnapshot     Json?    @map("price_snapshot")
  seatSnapshot      Json?    @map("seat_snapshot")
  pdfUrl            String?  @map("pdf_url")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("booking_central_snapshots")
}

// 24. payments
model Payment {
  id            String    @id @default(cuid())
  bookingId     String
  paymentRef    String    @unique
  amount             Float
  paymentMethod      String // CREDIT_CARD, BANK_TRANSFER, PROMPT_PAY
  status             String    @default("PENDING") // PENDING, COMPLETED, FAILED, REFUNDED
  slipUrl            String?   @db.Text
  verificationStatus String?   @default("PENDING") // PENDING, UPLOADED, VERIFIED, REJECTED
  paidAt             DateTime?
  createdAt          DateTime  @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// 25. invoices
model Invoice {
  id          String   @id @default(cuid())
  bookingId   String
  invoiceNo   String   @unique
  invoiceType String   @default("DEPOSIT") // DEPOSIT, BALANCE, FULL
  issueDate   DateTime @default(now())
  dueDate     DateTime
  totalAmount Float
  description String?  @db.Text
  pdfUrl      String?  @db.Text
  status      String   @default("UNPAID") // UNPAID, PARTIAL, PAID, VOID
  createdAt   DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

// 26. vouchers
model Voucher {
  id        String   @id @default(cuid())
  bookingId String
  voucherNo String   @unique
  issueDate DateTime @default(now())
  pdfUrl    String?
  status    String   @default("ACTIVE") // ACTIVE, USED, REVOKED
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("vouchers")
}

// 27. ai_conversations
model AiConversation {
  id               String   @id @default(cuid())
  userId           String?
  sessionId        String   @unique
  status           String   @default("ACTIVE")
  summary          String?  @db.Text
  totalTokens      Int      @default(0)
  estimatedCostUsd Float    @default(0)
  model            String   @default("gpt-4o-mini")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  AiMessage AiMessage[]

  @@map("ai_conversations")
}

// 28. ai_search_logs
model AiSearchLog {
  id            String   @id @default(cuid())
  sessionId     String
  queryText     String
  extractedJson Json?
  resultCount   Int      @default(0)
  createdAt     DateTime @default(now())

  @@map("ai_search_logs")
}

// 29. users
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  roleId       String
  agentId      String?
  supplierId   String?
  status             String   @default("ACTIVE")
  mustChangePassword Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  role            Role              @relation(fields: [roleId], references: [id], onDelete: Restrict)
  agent           Agent?            @relation(fields: [agentId], references: [id], onDelete: SetNull)
  supplier        Supplier?         @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  customer        Customer?
  conversations   AiConversation[]
  auditLogs       AuditLog[]
  saleLeads       Lead[]            @relation("SaleLeads")
  AiPromptVersion AiPromptVersion[]
  assignedTickets SupportTicket[]   @relation("StaffTickets")

  @@map("users")
}

// 30. roles
model Role {
  id          String   @id @default(cuid())
  name        String   @unique // ADMIN, AGENT_ADMIN, AGENT_USER, CUSTOMER
  description String?
  createdAt   DateTime @default(now())

  users       User[]
  permissions Permission[]

  @@map("roles")
}

// 31. permissions
model Permission {
  id        String   @id @default(cuid())
  roleId    String
  action    String // e.g., create:booking, read:tour
  resource  String // e.g., bookings, tours
  createdAt DateTime @default(now())

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, action, resource])
  @@map("permissions")
}

// 32. audit_logs
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String // CREATE, UPDATE, DELETE
  resource   String // bookings, prices, availability
  resourceId String
  oldValues  Json?
  newValues  Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

// 33. settings
model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  type        String   @default("STRING") // STRING, JSON, BOOLEAN, NUMBER
  description String?
  updatedAt   DateTime @updatedAt

  @@map("settings")
}

model ApiSyncLog {
  id             String   @id @default(cuid())
  supplierId     String   @default("UNKNOWN")
  type           String   @default("FULL_SYNC") // 'FULL_SYNC', 'AVAILABILITY_SYNC', 'PRICE_SYNC'
  status         String // 'RUNNING', 'SUCCESS', 'FAILED', 'RETRYING'
  recordsAdded   Int      @default(0)
  recordsUpdated Int      @default(0)
  errorMessage   String?
  createdAt      DateTime @default(now())
}

model LineChatSession {
  id         String   @id @default(cuid())
  lineUserId String   @unique
  status     String   @default("ACTIVE") // ACTIVE, CLOSED
  summary    String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  messages LineChatMessage[]
}

model LineChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String // USER, ASSISTANT, SYSTEM
  content   String   @db.Text
  createdAt DateTime @default(now())

  session LineChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model UserProfile {
  id          String   @id @default(cuid())
  userId      String   @unique // Can be Supabase Auth ID or LINE User ID
  preferences Json? // e.g. { favorite_destinations: [], budget: 20000, pax: 2 }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FitRequest {
  id           String   @id @default(cuid())
  serviceType  String // "FULL_SERVICE" or "A_LA_CARTE"
  name         String
  email        String?
  phone        String?
  pax          Int
  startDate    DateTime
  endDate      DateTime
  durationDays Int
  country      String
  cities       String

  // A La Carte Options
  includeFlights   Boolean @default(true)
  includeHotels    Boolean @default(true)
  includeMeals     Boolean @default(true)
  includeTransport Boolean @default(true)
  includeGuide     Boolean @default(true)
  includeInsurance Boolean @default(true)
  hotelStars       Int     @default(3)

  itinerary Json? // Stores the generated F.I.T. JSON

  status    String   @default("PENDING")
  createdAt DateTime @default(now())
}

model FlightPriceCache {
  id              Int       @id @default(autoincrement())
  originIata      String // e.g., "BKK"
  destinationIata String // e.g., "NRT"
  departureDate   DateTime?
  returnDate      DateTime?
  priceAmount     Float
  currency        String    @default("THB")
  provider        String // e.g., "AMADEUS_MOCK"
  fetchedAt       DateTime  @default(now())

  @@index([originIata, destinationIata])
}

model HotelPriceCache {
  id            Int      @id @default(autoincrement())
  city          String // e.g., "Tokyo"
  hotelStars    Int      @default(3) // 3, 4, 5
  pricePerNight Float
  currency      String   @default("THB")
  provider      String // e.g., "SERPAPI_MOCK"
  fetchedAt     DateTime @default(now())

  @@index([city, hotelStars])
}

model ActivityPriceCache {
  id                 Int      @id @default(autoincrement())
  provider           String // e.g., "VIATOR_MOCK", "TIQETS"
  providerProductId  String?
  destinationCountry String
  destinationCity    String?
  productName        String
  category           String // tour, attraction, ticket, day_trip
  durationText       String?
  priceFromAmount    Float
  currency           String   @default("THB")
  adultPrice         Float?
  childPrice         Float?
  rating             Float?
  reviewCount        Int?
  imageUrl           String?
  bookingUrl         String?
  fetchedAt          DateTime @default(now())
  expiresAt          DateTime
  note               String?

  @@index([destinationCountry, category])
}

// -----------------------------------------------------
// Link Health Monitor Models
// -----------------------------------------------------

model LinkAuditRun {
  id             String    @id @default(cuid())
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?
  status         String    @default("RUNNING") // RUNNING, COMPLETED, FAILED
  totalLinks     Int       @default(0)
  brokenLinks    Int       @default(0)
  criticalIssues Int       @default(0)
  summaryJson    Json?
  errorMessage   String?   @db.Text

  items LinkAuditItem[]

  @@map("link_audit_runs")
}

model LinkAuditItem {
  id            String  @id @default(cuid())
  runId         String
