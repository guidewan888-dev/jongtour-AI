generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role     @default(CUSTOMER)
  name      String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings  Booking[]
}

enum Role {
  CUSTOMER
  ADMIN
  SALES
}

model Tour {
  id             String          @id @default(cuid())
  source         TourSource      @default(MANUAL)
  providerId     String?         // ID จาก API (เช่น Zego, Go365)
  title          String
  destination    String
  durationDays   Int
  price          Float
  imageUrl       String?
  description    String?
  airlineCode    String?         // IATA code สายการบิน (เช่น TG, XJ)
  
  // New API fields
  pdfUrl         String?         // URL for PDF download
  itinerary      Json?           // Array of day-by-day itinerary
  flights        Json?           // Array of flight details
  embedding      Unsupported("vector(1536)")? // OpenAI Embeddings for Vector Search
  
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  departures     TourDeparture[]
}

enum TourSource {
  MANUAL
  API_ZEGO
  API_GO365
  CHECKIN
  TOUR_FACTORY
}

model TourDeparture {
  id             String    @id @default(cuid())
  tourId         String
  startDate      DateTime
  endDate        DateTime
  price          Float
  childPrice     Float?
  singleRoomPrice Float?
  depositPrice   Float?
  availableSeats Int
  totalSeats     Int
  
  tour           Tour      @relation(fields: [tourId], references: [id])
  bookings       Booking[]
}

model Booking {
  id            String        @id @default(cuid())
  userId        String
  departureId   String
  status        BookingStatus @default(PENDING)
  totalPrice    Float
  contactName   String?
  contactPhone  String?
  pax           Int           @default(1)
  adults        Int           @default(1)
  children      Int           @default(0)
  singleRooms   Int           @default(0)
  paymentType   String        @default("full")
  depositAmount Float?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user          User          @relation(fields: [userId], references: [id])
  departure     TourDeparture @relation(fields: [departureId], references: [id])
  travelers     Traveler[]
  payments      Payment[]
}

enum BookingStatus {
  PENDING
  AWAITING_CONFIRMATION
  DEPOSIT_PAID
  FULL_PAID
  CANCELLED
}

model Traveler {
  id              String   @id @default(cuid())
  bookingId       String
  name            String
  passportNo      String?
  dob             DateTime?
  passportFileUrl String?
  visaFileUrl     String?

  booking     Booking  @relation(fields: [bookingId], references: [id])
}

model Payment {
  id          String        @id @default(cuid())
  bookingId   String
  amount      Float
  slipUrl     String?
  status      PaymentStatus @default(PENDING)
  type        PaymentType   @default(FULL)
  createdAt   DateTime      @default(now())

  booking     Booking       @relation(fields: [bookingId], references: [id])
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentType {
  DEPOSIT
  FULL
}

model ApiSyncLog {
  id            String   @id @default(cuid())
  providerName  String   // 'ZEGO', 'GO365'
  status        String   // 'RUNNING', 'SUCCESS', 'FAILED'
  recordsAdded  Int      @default(0)
  recordsUpdated Int     @default(0)
  errorMessage  String?
  createdAt     DateTime @default(now())
}

model LineChatSession {
  id         String   @id @default(cuid())
  lineUserId String   @unique
  status     String   @default("ACTIVE") // ACTIVE, CLOSED
  summary    String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  messages   LineChatMessage[]
}

model LineChatMessage {
  id         String   @id @default(cuid())
  sessionId  String
  role       String   // USER, ASSISTANT, SYSTEM
  content    String   @db.Text
  createdAt  DateTime @default(now())

  session    LineChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model FitRequest {
  id              String   @id @default(cuid())
  serviceType     String   // "FULL_SERVICE" or "A_LA_CARTE"
  name            String
  email           String?
  phone           String?
  pax             Int
  startDate       DateTime
  endDate         DateTime
  durationDays    Int
  country         String
  cities          String
  
  // A La Carte Options
  includeFlights  Boolean  @default(true)
  includeHotels   Boolean  @default(true)
  includeMeals    Boolean  @default(true)
  includeTransport Boolean @default(true)
  includeGuide    Boolean  @default(true)
  includeInsurance Boolean @default(true)
  hotelStars      Int      @default(3)
  
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())
}

model FlightPriceCache {
  id              Int      @id @default(autoincrement())
  originIata      String   // e.g., "BKK"
  destinationIata String   // e.g., "NRT"
  departureDate   DateTime?
  returnDate      DateTime?
  priceAmount     Float
  currency        String   @default("THB")
  provider        String   // e.g., "AMADEUS_MOCK"
  fetchedAt       DateTime @default(now())
  
  @@index([originIata, destinationIata])
}

model HotelPriceCache {
  id              Int      @id @default(autoincrement())
  city            String   // e.g., "Tokyo"
  hotelStars      Int      @default(3) // 3, 4, 5
  pricePerNight   Float
  currency        String   @default("THB")
  provider        String   // e.g., "SERPAPI_MOCK"
  fetchedAt       DateTime @default(now())
  
  @@index([city, hotelStars])
}
