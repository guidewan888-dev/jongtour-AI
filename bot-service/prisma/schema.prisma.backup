generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Company {
  id          String      @id @default(cuid())
  name        String
  type        CompanyType @default(AGENT)
  creditLimit Float       @default(0)
  balance     Float       @default(0)
  subdomain   String?     @unique
  logoUrl     String?
  themeColor  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  users       User[]
  tours       Tour[]      @relation("SupplierTours")
  bookings    Booking[]   @relation("AgentBookings")
}

enum CompanyType {
  ADMIN
  SUPPLIER
  AGENT
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role     @default(CUSTOMER)
  name      String?
  phone     String?
  companyId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company? @relation(fields: [companyId], references: [id])
  bookings  Booking[]
}

enum Role {
  CUSTOMER
  ADMIN
  SALES
  OPS
  SUPPLIER
  AGENT
}

model Tour {
  id             String          @id @default(cuid())
  source         TourSource      @default(MANUAL)
  providerId     String?         // ID จาก API (เช่น Zego, Go365)
  externalTourId String?         // ID แท้จริงจากฝั่ง Supplier
  supplierId     String?
  title          String
  destination    String
  durationDays   Int
  price          Float
  imageUrl       String?
  description    String?
  airlineCode    String?         // IATA code สายการบิน (เช่น TG, XJ)
  isActive       Boolean         @default(true) // สำหรับ Soft Delete เวลา Supplier ลบโปรแกรม
  
  // New API fields
  pdfUrl         String?         // URL for PDF download
  itinerary      Json?           // Array of day-by-day itinerary
  flights        Json?           // Array of flight details
  embedding      Unsupported("vector(1536)")? // OpenAI Embeddings for Vector Search
  
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  supplier       Company?        @relation("SupplierTours", fields: [supplierId], references: [id])
  departures     TourDeparture[]
}

enum TourSource {
  MANUAL
  API_ZEGO
  API_GO365
  CHECKIN
  TOUR_FACTORY
}

model TourDeparture {
  id                  String    @id @default(cuid())
  tourId              String
  externalDepartureId String?   // รหัสรอบเดินทางของ Supplier
  startDate           DateTime
  endDate             DateTime
  price               Float
  netPrice            Float?
  childPrice          Float?
  singleRoomPrice     Float?
  depositPrice        Float?
  availableSeats      Int
  totalSeats          Int
  status              String    @default("AVAILABLE") // AVAILABLE, FULL, CANCELLED
  
  tour                Tour      @relation(fields: [tourId], references: [id])
  bookings            Booking[]
  priceHistories      TourPriceHistory[]
}

model TourPriceHistory {
  id             String   @id @default(cuid())
  departureId    String
  oldPrice       Float
  newPrice       Float
  oldNetPrice    Float?
  newNetPrice    Float?
  changedAt      DateTime @default(now())

  departure      TourDeparture @relation(fields: [departureId], references: [id])
}

model Booking {
  id            String        @id @default(cuid())
  userId        String
  departureId   String
  agentId       String?
  status        BookingStatus @default(PENDING)
  totalPrice    Float
  contactName   String?
  contactPhone  String?
  pax           Int           @default(1)
  adults        Int           @default(1)
  children      Int           @default(0)
  singleRooms   Int           @default(0)
  paymentType   String        @default("full")
  depositAmount Float?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user          User          @relation(fields: [userId], references: [id])
  departure     TourDeparture @relation(fields: [departureId], references: [id])
  agent         Company?      @relation("AgentBookings", fields: [agentId], references: [id])
  travelers     Traveler[]
  payments      Payment[]
}

enum BookingStatus {
  PENDING
  AWAITING_CONFIRMATION
  DEPOSIT_PAID
  FULL_PAID
  CANCELLED
}

model Traveler {
  id              String   @id @default(cuid())
  bookingId       String
  name            String
  passportNo      String?
  dob             DateTime?
  passportFileUrl String?
  visaFileUrl     String?

  booking     Booking  @relation(fields: [bookingId], references: [id])
}

model Payment {
  id          String        @id @default(cuid())
  bookingId   String
  amount      Float
  slipUrl     String?
  status      PaymentStatus @default(PENDING)
  type        PaymentType   @default(FULL)
  createdAt   DateTime      @default(now())

  booking     Booking       @relation(fields: [bookingId], references: [id])
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentType {
  DEPOSIT
  FULL
}

model ApiSyncLog {
  id            String   @id @default(cuid())
  supplierId    String   @default("UNKNOWN")
  type          String   @default("FULL_SYNC") // 'FULL_SYNC', 'AVAILABILITY_SYNC', 'PRICE_SYNC'
  status        String   // 'RUNNING', 'SUCCESS', 'FAILED', 'RETRYING'
  recordsAdded  Int      @default(0)
  recordsUpdated Int     @default(0)
  errorMessage  String?
  createdAt     DateTime @default(now())
}

model SupplierApiCredential {
  id          String   @id @default(cuid())
  supplierId  String   @unique
  baseUrl     String
  apiKey      String   // Encrypted
  apiSecret   String?  // Encrypted
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TourRawData {
  id             String   @id @default(cuid())
  externalTourId String
  supplierId     String
  rawPayload     Json     // ข้อมูลดิบจาก Supplier
  syncStatus     String   @default("PENDING") // 'PENDING', 'PROCESSED', 'FAILED'
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  @@unique([supplierId, externalTourId])
}

model LineChatSession {
  id         String   @id @default(cuid())
  lineUserId String   @unique
  status     String   @default("ACTIVE") // ACTIVE, CLOSED
  summary    String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  messages   LineChatMessage[]
}

model LineChatMessage {
  id         String   @id @default(cuid())
  sessionId  String
  role       String   // USER, ASSISTANT, SYSTEM
  content    String   @db.Text
  createdAt  DateTime @default(now())

  session    LineChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model UserProfile {
  id          String   @id @default(cuid())
  userId      String   @unique // Can be Supabase Auth ID or LINE User ID
  preferences Json?    // e.g. { favorite_destinations: [], budget: 20000, pax: 2 }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FitRequest {
  id              String   @id @default(cuid())
  serviceType     String   // "FULL_SERVICE" or "A_LA_CARTE"
  name            String
  email           String?
  phone           String?
  pax             Int
  startDate       DateTime
  endDate         DateTime
  durationDays    Int
  country         String
  cities          String
  
  // A La Carte Options
  includeFlights  Boolean  @default(true)
  includeHotels   Boolean  @default(true)
  includeMeals    Boolean  @default(true)
  includeTransport Boolean @default(true)
  includeGuide    Boolean  @default(true)
  includeInsurance Boolean @default(true)
  hotelStars      Int      @default(3)
  
  itinerary       Json?    // Stores the generated F.I.T. JSON
  
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())
}

model FlightPriceCache {
  id              Int      @id @default(autoincrement())
  originIata      String   // e.g., "BKK"
  destinationIata String   // e.g., "NRT"
  departureDate   DateTime?
  returnDate      DateTime?
  priceAmount     Float
  currency        String   @default("THB")
  provider        String   // e.g., "AMADEUS_MOCK"
  fetchedAt       DateTime @default(now())
  
  @@index([originIata, destinationIata])
}

model HotelPriceCache {
  id              Int      @id @default(autoincrement())
  city            String   // e.g., "Tokyo"
  hotelStars      Int      @default(3) // 3, 4, 5
  pricePerNight   Float
  currency        String   @default("THB")
  provider        String   // e.g., "SERPAPI_MOCK"
  fetchedAt       DateTime @default(now())
  
  @@index([city, hotelStars])
}

model ActivityPriceCache {
  id                  Int      @id @default(autoincrement())
  provider            String   // e.g., "VIATOR_MOCK", "TIQETS"
  providerProductId   String?
  destinationCountry  String
  destinationCity     String?
  productName         String
  category            String   // tour, attraction, ticket, day_trip
  durationText        String?
  priceFromAmount     Float
  currency            String   @default("THB")
  adultPrice          Float?
  childPrice          Float?
  rating              Float?
  reviewCount         Int?
  imageUrl            String?
  bookingUrl          String?
  fetchedAt           DateTime @default(now())
  expiresAt           DateTime
  note                String?

  @@index([destinationCountry, category])
}
